{
  "name": "sharmaprakash-astro",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host",
    "start": "astro dev --host",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "search:index": "astro build && pagefind --site dist --output-path public/pagefind",
    "check": "astro check",
    "presentations:build": "node scripts/presentations/build-presentations.mjs",
    "presentations:check": "node scripts/presentations/check-presentations.mjs",
    "blog-image:render": "node scripts/images/render-blog-header.mjs",
    "podcast:bundle": "node scripts/podcast/bundle.mjs",
    "podcast:dialogue": "node scripts/podcast/dialogue.mjs",
    "podcast:monologue": "node scripts/podcast/monologue.mjs",
    "podcast:finalize": "scripts/podcast/finalize.sh",
    "podcast:publish": "scripts/podcast/publish.sh",
    "z": "zellij attach sharmaprakash 2>/dev/null || zellij -s sharmaprakash -n .zellij/layouts/default.kdl",
    "cmux:up": "scripts/cmux-up.sh",
    "cmux:reset": "scripts/cmux-up.sh --reset",
    "cmux:recreate": "scripts/cmux-up.sh --recreate",
    "cmux:down": "scripts/cmux-down.sh"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@iconify/react": "^6.0.2",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^7.1.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.25.0",
    "react": "^19.2.8",
    "react-d3-tree": "^3.6.6",
    "react-dom": "^19.2.8",
    "react-icons": "^5.7.0",
    "recharts": "^3.10.0",
    "rehype-pretty-code": "^0.14.4",
    "satori": "^0.26.0",
    "sharp": "^0.35.3",
    "shiki": "^4.3.1",
    "swiper": "^14.0.6"
  },
  "devDependencies": {
    "@marp-team/marp-cli": "^4.5.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/vite": "^4.3.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "pagefind": "^1.5.2",
    "postcss": "^8.5.22",
    "qrcode": "^1.5.4",
    "sass": "^1.101.3",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.5"
  }
}
