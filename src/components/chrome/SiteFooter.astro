---
import { Icon } from "@iconify/react";
import { information, bookingUrl } from "~/data/site";
import { getAllCategories, getUniqueCategories } from "~/utils/posts";
import { createSlug } from "~/utils";
import { courseRegistry } from "~/data/courses";
import { courseUrl } from "~/utils/courses";

const year = new Date().getFullYear();

const categories = await getUniqueCategories();
const allCategories = await getAllCategories();
const categoryCounts = Object.fromEntries(
  categories.map((c) => [c, allCategories.filter((x) => x === c).length]),
);
const topics = categories.sort((a, b) => categoryCounts[b] - categoryCounts[a]);

const courses = Object.entries(courseRegistry).map(([slug, meta]) => ({ slug, meta }));
---

<footer class="site-footer">
  <span class="cta-glow" aria-hidden="true"></span>

  <div class="site-footer-inner">
    <div class="site-footer-cta">
      <p class="eyebrow text-accent-500">Want to compare notes?</p>
      <h2 class="site-footer-headline">
        On product, engineering, or the awkward space
        <span class="shape">between</span>.
      </h2>
      <p class="site-footer-lede">
        I'm full-time at Varicon, but I'm always up for a thoughtful conversation
        about product craft, team-building, or the founder-to-operator transition.
      </p>
      <a
        href={bookingUrl}
        target="_blank"
        rel="noopener"
        data-track="booking_click"
        data-track-location="footer"
        class="cta-btn btn btn-primary btn-lg"
      >
        <span>Say hello</span>
        <Icon icon="ri:arrow-right-line" client:load />
      </a>
    </div>

    <div class="site-footer-explore">
      {topics.length > 0 && (
        <div class="site-footer-explore-col">
          <p class="eyebrow text-on-inverse-muted mb-3">Topics</p>
          <ul class="site-footer-chips">
            {topics.map((c) => (
              <li>
                <a href={`/category/${createSlug(c)}/1/`} class="chip chip-inverse">
                  {c} <span class="chip-count">({categoryCounts[c]})</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {courses.length > 0 && (
        <div class="site-footer-explore-col">
          <p class="eyebrow text-on-inverse-muted mb-3">Courses</p>
          <ul class="site-footer-courses">
            {courses.map(({ slug, meta }) => (
              <li>
                <a href={courseUrl(slug)} class="link-underline">
                  {meta.title}
                  <span class="chip-count">({meta.chapters.length} ch.)</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="site-footer-explore-col">
        <p class="eyebrow text-on-inverse-muted mb-3">Tools</p>
        <ul class="site-footer-courses">
          <li>
            <a href="/tools/opportunity-solution-tree/" class="link-underline">
              Opportunity Solution Tree Builder
              <span class="chip-count">(free)</span>
            </a>
          </li>
          <li>
            <a href="/tools/decision-door-classifier/" class="link-underline">
              Decision Door Classifier
              <span class="chip-count">(free)</span>
            </a>
          </li>
          <li>
            <a href="/tools/pr-faq-builder/" class="link-underline">
              PR/FAQ Builder
              <span class="chip-count">(free)</span>
            </a>
          </li>
          <li>
            <a href="/tools/backlog-triage/" class="link-underline">
              Backlog Triage Board
              <span class="chip-count">(free)</span>
            </a>
          </li>
          <li>
            <a href="/tools/agreement-certainty-matrix/" class="link-underline">
              Agreement-Certainty Matrix
              <span class="chip-count">(free)</span>
            </a>
          </li>
          <li>
            <a href="/tools/story-map/" class="link-underline">
              Story Map Builder
              <span class="chip-count">(free)</span>
            </a>
          </li>
          <li>
            <a href="/tools/north-star-metric-tree/" class="link-underline">
              North Star Metric Tree
              <span class="chip-count">(free)</span>
            </a>
          </li>
          <li>
            <a href="/tools/okr-organizer/" class="link-underline">
              OKR Organizer
              <span class="chip-count">(free)</span>
            </a>
          </li>
          <li>
            <a href="/tools/spec-builder/" class="link-underline">
              Spec Builder
              <span class="chip-count">(free)</span>
            </a>
          </li>
          <li>
            <a href="/tools/vertical-slicer/" class="link-underline">
              Vertical Slicer
              <span class="chip-count">(free)</span>
            </a>
          </li>
          <li>
            <a href="/tools/backlog-prioritizer/" class="link-underline">
              Backlog Prioritizer
              <span class="chip-count">(free)</span>
            </a>
          </li>
          <li>
            <a href="/tools/cadence-reflection-kit/" class="link-underline">
              Cadence &amp; Reflection Kit
              <span class="chip-count">(free)</span>
            </a>
          </li>
          <li>
            <a href="/tools/okr-check-in/" class="link-underline">
              OKR Check-In
              <span class="chip-count">(free)</span>
            </a>
          </li>
          <li>
            <a href="/tools/test-register/" class="link-underline">
              Test Register
              <span class="chip-count">(free)</span>
            </a>
          </li>
          <li>
            <a href="/tools/stakeholder-update-composer/" class="link-underline">
              Stakeholder Update Composer
              <span class="chip-count">(free)</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="site-footer-meta">
      <span class="site-footer-copy">© {year} {information.fullName}</span>
      <div class="site-footer-socials">
        <a
          href={information.socialAddress.facebook}
          aria-label="Facebook"
          data-track="social_click"
          data-track-network="facebook"
          class="iconwrap icon-morph"
        >
          <Icon icon="ri:facebook-fill" width="20" height="20" client:load />
        </a>
        <a
          href={information.socialAddress.twitter}
          aria-label="Twitter"
          data-track="social_click"
          data-track-network="twitter"
          class="iconwrap icon-morph"
        >
          <Icon icon="ri:twitter-x-fill" width="20" height="20" client:load />
        </a>
        <a
          href={information.socialAddress.linkedin}
          aria-label="LinkedIn"
          data-track="social_click"
          data-track-network="linkedin"
          class="iconwrap icon-morph"
        >
          <Icon icon="ri:linkedin-fill" width="20" height="20" client:load />
        </a>
        <a
          href={information.socialAddress.github}
          aria-label="GitHub"
          data-track="social_click"
          data-track-network="github"
          class="iconwrap icon-morph"
        >
          <Icon icon="ri:github-fill" width="20" height="20" client:load />
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    isolation: isolate;
    background: var(--surface-inverse);
    color: var(--text-on-inverse);
    padding: var(--space-20) var(--space-6);
    text-align: center;
    overflow: hidden;
  }
  @media (min-width: 1024px) {
    .site-footer {
      min-height: 100vh;
      padding-block: var(--space-32);
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }

  /* Ambient glow orbs — bright enough to be visible on the dark band. */
  .cta-glow {
    position: absolute;
    left: 50%;
    top: 35%;
    width: 70%;
    height: 70%;
    transform: translate(-50%, -50%);
    background: radial-gradient(closest-side, var(--accent-600), transparent 70%);
    opacity: 0.55;
    filter: blur(60px);
    z-index: 0;
    pointer-events: none;
    border-radius: 9999px;
    animation: cta-glow-pulse 6s var(--ease-in-out-cubic) infinite;
  }
  @keyframes cta-glow-pulse {
    0%, 100% { opacity: 0.45; transform: translate(-50%, -50%) scale(1); }
    50%      { opacity: 0.7;  transform: translate(-50%, -50%) scale(1.08); }
  }

  .site-footer-inner {
    position: relative;
    z-index: 1;
    margin-inline: auto;
    max-width: 56rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    width: 100%;
  }

  .site-footer-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .site-footer-headline {
    color: var(--text-on-inverse);
    font-size: 36px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0;
    max-width: 22ch;
  }
  @media (min-width: 1024px) {
    .site-footer-headline { font-size: 48px; line-height: 1.1; }
  }

  /* Hand-drawn scribble accent — pinned behind one word, drawn in amber. */
  .shape {
    position: relative;
    display: inline-block;
    white-space: nowrap;
    color: var(--accent-500);
    isolation: isolate;
  }
  .shape::before {
    content: "";
    position: absolute;
    left: 100%;
    top: 50%;
    width: 220px;
    height: 220px;
    transform: translate(-30%, -80%);
    background-image: url("/images/asset/line.png");
    background-repeat: no-repeat;
    background-size: contain;
    background-position: center;
    opacity: 0.9;
    /* Tint the line.png to our accent amber via filter. */
    filter: brightness(0) saturate(100%)
      invert(56%) sepia(95%) saturate(1845%) hue-rotate(2deg)
      brightness(98%) contrast(101%);
    pointer-events: none;
    z-index: -1;
  }
  @media (max-width: 640px) {
    .shape::before { width: 160px; height: 160px; }
  }

  .site-footer-lede {
    font-size: 18px;
    line-height: 1.65;
    color: var(--text-on-inverse-muted);
    max-width: 36rem;
    margin: 0;
  }

  .cta-btn {
    transition:
      transform var(--dur-fast) var(--ease-out-quad),
      box-shadow var(--dur-normal) var(--ease-out-quad);
  }
  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow:
      0 10px 24px -10px color-mix(in oklab, var(--accent-600), transparent 50%);
  }

  .site-footer-explore {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    text-align: left;
    border-top: 1px solid color-mix(in oklab, var(--ink-50), transparent 90%);
    padding-top: var(--space-8);
  }
  @media (min-width: 640px) {
    .site-footer-explore {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
    }
  }
  @media (min-width: 900px) {
    .site-footer-explore {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .site-footer-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .chip-inverse {
    background: color-mix(in oklab, var(--ink-50), transparent 92%);
    color: var(--text-on-inverse);
    border-color: transparent;
  }
  a.chip-inverse:hover {
    background: var(--accent-600);
    color: #fff;
    border-color: transparent;
  }

  .chip-count {
    opacity: 0.7;
    font-size: 0.9em;
  }

  .site-footer-courses {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .site-footer-courses a {
    color: var(--text-on-inverse);
    font-size: 15px;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2);
  }
  .site-footer-courses .chip-count {
    color: var(--text-on-inverse-muted);
    font-size: 13px;
  }

  .site-footer-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    border-top: 1px solid color-mix(in oklab, var(--ink-50), transparent 90%);
    padding-top: var(--space-8);
  }
  @media (min-width: 768px) {
    .site-footer-meta {
      flex-direction: row;
      justify-content: space-between;
      gap: var(--space-6);
    }
  }

  .site-footer-copy {
    color: var(--text-on-inverse-muted);
    font-size: 14px;
  }

  .site-footer-socials {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .iconwrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 9999px;
    background: color-mix(in oklab, var(--ink-50), transparent 92%);
    color: var(--text-on-inverse);
    transition:
      background-color var(--dur-fast) var(--ease-out-quad),
      color var(--dur-fast) var(--ease-out-quad),
      transform var(--dur-normal) var(--ease-out-quad);
  }
  .iconwrap:hover {
    background: var(--accent-600);
    color: #fff;
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-glow { animation: none; }
    .cta-btn,
    .iconwrap { transition: none; transform: none !important; }
  }
</style>
