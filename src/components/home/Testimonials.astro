---
import { Icon } from "@iconify/react";
import { clientReview } from "~/data/reviews";
---

<section class="testimonial-section relative bg-primary-50 dark:bg-dark-300">
  <swiper-container
    class="testimonial-swiper"
    slides-per-view="1"
    loop="true"
    autoplay-delay="6000"
    autoplay-disable-on-interaction="false"
    navigation-next-el=".testimonial-next"
    navigation-prev-el=".testimonial-prev"
  >
    {clientReview.map((data) => (
      <swiper-slide>
        <div class="testimonials dark:bg-dark-300">
          <div class="inconwrap">
            <Icon
              icon="ri:double-quotes-l"
              height="62"
              className="mx-auto text-primary-1000 dark:text-primary-300"
              client:load
            />
          </div>
          <div class="mx-auto max-w-full pb-12 text-center">
            <p class="text-2xl dark:text-white" set:html={data.text} />
          </div>
          <div class="testimonial-name flex items-center justify-center">
            <div class="roundimg">
              <img src={data.image} alt={data.name} class="w-16 h-16 rounded-full object-cover" />
            </div>
            <div class="px-5 text-left">
              <strong class="mb-0 text-lg dark:text-white block">{data.name}</strong>
              <p class="text-sm dark:text-white">{data.meta}</p>
            </div>
          </div>
        </div>
      </swiper-slide>
    ))}
  </swiper-container>

  <div class="hidden lg:flex absolute left-1/2 -translate-x-1/2 bottom-10 gap-3 z-10">
    <button type="button" aria-label="Previous" class="testimonial-prev nav-circle">
      <svg width="40" height="40" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M11 16H21M11 16L15.5 20.5M11 16L15.5 11.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
        <rect x="0.5" y="0.5" width="31" height="31" rx="15.5" stroke="currentColor" />
      </svg>
    </button>
    <button type="button" aria-label="Next" class="testimonial-next nav-circle">
      <svg width="40" height="40" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M21 16H11M21 16L16.5 11.5M21 16L16.5 20.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
        <rect x="0.5" y="0.5" width="31" height="31" rx="15.5" stroke="currentColor" />
      </svg>
    </button>
  </div>
</section>

<style is:global>
  .nav-circle {
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
    border-radius: 9999px;
    color: #334155;
  }
  .nav-circle svg rect,
  .nav-circle svg path {
    transition: stroke 0.2s, fill 0.2s;
  }
  .nav-circle svg rect { fill: transparent; stroke: currentColor; }
  .nav-circle svg path { stroke: currentColor; }
  .nav-circle:hover svg rect { fill: rgb(var(--color-300)); stroke: rgb(var(--color-300)); }
  .nav-circle:hover svg path { stroke: #ffffff; }
  .dark .nav-circle { color: #ffffff; }
</style>

<script>
  import { register } from "swiper/element/bundle";
  register();
</script>
