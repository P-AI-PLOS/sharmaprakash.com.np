---
import { Icon } from "@iconify/react";
import { information } from "~/data/site";
import { companyInformation } from "~/data/companies";
import SiteNav from "~/components/SiteNav.astro";

const ARROW_RIGHT = `<svg width="28" height="28" viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg" class="fill-primary-300 pl-1.5"><path d="M13.3876 22.6917C13.232 22.5361 13.1542 22.3319 13.1542 22.0792C13.1542 21.8264 13.232 21.6222 13.3876 21.4667L19.9792 14.875H5.54175C5.28897 14.875 5.07994 14.7924 4.91466 14.6271C4.74939 14.4618 4.66675 14.2528 4.66675 14C4.66675 13.7472 4.74939 13.5382 4.91466 13.3729C5.07994 13.2076 5.28897 13.125 5.54175 13.125H19.9792L13.3876 6.53334C13.232 6.37778 13.1542 6.16875 13.1542 5.90625C13.1542 5.64375 13.232 5.43473 13.3876 5.27917C13.5431 5.12362 13.7473 5.04584 14.0001 5.04584C14.2529 5.04584 14.457 5.12362 14.6126 5.27917L22.7209 13.3875C22.8181 13.4847 22.8862 13.5819 22.9251 13.6792C22.964 13.7764 22.9834 13.8833 22.9834 14C22.9834 14.0972 22.964 14.1993 22.9251 14.3063C22.8862 14.4132 22.8181 14.5153 22.7209 14.6125L14.6126 22.7208C14.457 22.8764 14.2529 22.9493 14.0001 22.9396C13.7473 22.9299 13.5431 22.8472 13.3876 22.6917Z" /></svg>`;

const companyLogos = [
  { src: "/images/asset/truemark.png", alt: "truemark" },
  { src: "/images/asset/invoiceWork.png", alt: "invoice work" },
  { src: "/images/asset/allBrainyLabs.png", alt: "all brainy labs" },
];
const skillLogos = [
  { src: "/images/asset/spree-01.png", alt: "spree" },
  { src: "/images/asset/react.png", alt: "react" },
  { src: "/images/asset/gatsby.png", alt: "gatsby" },
  { src: "/images/asset/ruby.png", alt: "rails" },
];
---

<div class="flex flex-col items-start lg:flex-row">
  <div class="sticky-element h-auto w-full lg:sticky lg:top-0 lg:self-start lg:w-1/2">
    <div class="h-auto w-full bg-primary-900 p-6 dark:bg-dark-50 lg:h-screen lg:py-20 lg:pl-28">
      <div class="flex h-full flex-col">
        <SiteNav />

        <div class="my-36 lg:my-auto">
          <div class="max-w-2xl py-2 lg:py-12">
            <p class="text-white">Prakash Poudel</p>
            <h1>Developer Turned Entrepreneur</h1>
            <div class="py-4 lg:pr-16">
              <p class="text-lg text-gray-300">
                Over 8 years of industry experience in Game/Frontend development with special
                interest in e-commerce, analytics and startups.
              </p>
            </div>
          </div>
          <a href="/contact/" class="btn btn-primary"><span>Book Your Consultation</span></a>
        </div>

        <div class="flex items-center gap-4 text-white">
          <span class="mb-0 text-lg font-semibold text-white">Find me at:</span>
          <a href={information.socialAddress.facebook} aria-label="Facebook">
            <span class="iconwrap"><Icon icon="ei:sc-facebook" width="32" height="32" client:load /></span>
          </a>
          <a href={information.socialAddress.twitter} aria-label="Twitter">
            <span class="iconwrap"><Icon icon="ei:sc-twitter" width="32" height="32" client:load /></span>
          </a>
          <a href={information.socialAddress.linkedin} aria-label="LinkedIn">
            <span class="iconwrap"><Icon icon="ei:sc-linkedin" width="32" height="32" client:load /></span>
          </a>
          <a href={information.socialAddress.github} aria-label="GitHub">
            <span class="iconwrap"><Icon icon="ei:sc-github" width="32" height="32" client:load /></span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="w-full lg:w-1/2">
    <figure class="overflow-hidden lg:h-screen">
      <img
        src="/images/asset/prakash.jpg"
        alt={information.fullName}
        class="h-auto w-auto lg:h-full lg:w-full lg:object-cover"
      />
    </figure>

    <div class="flex flex-col justify-center bg-white px-4 py-4 lg:h-screen lg:px-14 lg:py-10 dark:bg-dark-100">
      <div class="max-w-md">
        <h2 class="dark:text-white">Want to learn more about my business?</h2>
        <p class="text-lg dark:text-white">
          Over 8 years of industry experience in Game/Frontend development with special interest.
        </p>
      </div>
      <div>
        <div class="py-8" id="company-tabs">
          <div class="tab-list flex gap-2.5 border-b border-gray-200 dark:border-white/10">
            {companyLogos.map((l, i) => (
              <button
                type="button"
                data-tab-index={i}
                class:list={["custom-tab", "dark:grayscale", { "is-active": i === 0 }]}
              >
                <img src={l.src} alt={l.alt} />
              </button>
            ))}
          </div>
          {companyInformation.map((c, i) => (
            <div class="tab-panel" data-panel-index={i} hidden={i !== 0}>
              <p class="text-lg dark:text-white pt-6" set:html={c.companyDescription} />
              <div class="pt-16 lg:pt-20">
                <a href={c.siteUrl} class="btn-link flex items-center">
                  <span class="text-primary-300">Visit Website</span>
                  <Fragment set:html={ARROW_RIGHT} />
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="flex flex-col justify-center px-4 lg:h-screen lg:px-14 lg:pt-2 dark:bg-dark-100">
      <div>
        <h2 class="mt-20 dark:text-white">Go-to guide for product &amp; technical matter</h2>
        <p class="text-lg dark:text-white">
          Over 8 years of industry experience in Game/Frontend development with special interest.
        </p>
      </div>

      <div class="skill-block py-2 lg:py-8 flex items-center gap-8 flex-wrap">
        {skillLogos.map((l) => (
          <figure class="skill-img"><img src={l.src} alt={l.alt} /></figure>
        ))}
      </div>

      <div class="relative top-0 flex">
        <p
          id="slant-text"
          class="py-9 pt-16 text-lg text-black lg:pt-48 dark:text-white flex relative"
        >
          Here's what people had to<br /> about our consultation
          <svg
            width="66"
            height="75"
            viewBox="0 0 66 75"
            xmlns="http://www.w3.org/2000/svg"
            class="fill-primary-300 absolute block right-[-100px]"
          >
            <path d="M34.1951 35.717C34.4677 35.3359 34.6733 34.9012 35.0073 34.5146C37.1168 32.0069 39.1593 29.4457 41.3359 26.9915C42.2822 25.8961 43.4354 25.02 44.5101 23.9726C44.6271 23.9027 44.7384 23.7738 44.8554 23.7039C47.9367 21.6448 50.7119 22.8246 51.0537 26.3625C51.2587 28.4853 51.0286 30.5874 50.9882 32.7321C50.8316 38.1582 50.6807 43.6432 50.5854 49.0639C50.4718 53.6535 50.4195 58.2377 50.3116 62.8863C50.54 62.6875 50.7626 62.4297 50.9853 62.172C52.905 59.6217 54.6964 57.0235 56.6832 54.5268C58.2804 52.4811 60.0117 50.5424 61.743 48.6038C62.1326 48.1527 62.6222 47.4548 63.2814 47.8718C64.0076 48.3423 63.5237 49.0991 63.2682 49.6572C62.3845 51.4013 61.568 53.1989 60.4889 54.8415C57.5912 59.4416 54.5652 63.9937 51.5391 68.5457C51.1608 69.1148 50.7269 69.7482 50.2146 70.2102C48.7945 71.5264 47.1149 71.4383 45.8567 69.9448C45.6441 69.6664 45.4315 69.388 45.2803 69.1041C43.3432 65.7085 41.6515 62.2909 40.3722 58.6582C40.2039 58.1974 40.0913 57.6722 40.1014 57.136C40.0444 56.5464 40.367 56.0418 40.9635 55.8102C41.56 55.5785 42.1907 55.7007 42.5488 56.204C42.9682 56.7019 43.3934 57.2587 43.6958 57.8264C44.7428 59.6957 45.6728 61.6348 46.6585 63.5095C46.8824 63.9059 47.1007 64.2432 47.3974 64.752C47.1446 58.2919 46.7192 51.9662 46.6734 45.7255C46.6218 39.4258 46.8827 33.1578 47.0595 26.6594C46.6528 26.9335 46.2347 27.0898 45.9506 27.353C44.7646 28.5294 43.5172 29.7112 42.4039 31C40.1774 33.5776 38.0235 36.2676 35.797 38.8452C35.3017 39.4841 34.745 40.1285 34.1156 40.6605C32.6842 41.8587 30.9591 41.2989 30.42 39.5628C30.2289 38.8661 30.1606 38.1585 30.215 37.44C30.6411 32.882 31.0002 28.2704 31.549 23.7014C31.9707 19.7385 32.5823 15.8182 33.004 11.8553C33.1741 10.4127 33.1544 8.92763 32.9506 7.45896C32.8025 5.92585 32.082 5.51434 30.6606 6.1764C29.5346 6.69317 28.353 7.27438 27.4453 8.12851C25.2788 10.0465 23.1179 12.0235 21.2254 14.2145C15.342 21.222 10.1792 28.641 5.86542 36.5196C5.65415 36.8953 5.56561 37.26 5.28159 37.5232C4.99757 37.7865 4.52378 38.0072 4.14992 37.981C3.59198 37.9713 3.29527 37.4625 3.31106 36.9853C3.32685 36.5081 3.404 36.0255 3.60957 35.5908C4.00931 34.6036 4.46472 33.5519 4.99288 32.6127C9.04548 25.2332 13.7573 18.2707 19.3907 11.8802C21.2277 9.75372 23.3942 7.8357 25.4993 5.92315C26.4684 5.06354 27.6443 4.42337 28.826 3.84216C29.4111 3.49259 30.0804 3.37341 30.7439 3.19527C33.2369 2.73497 35.069 3.76102 35.9161 6.12388C36.6007 8.08492 36.5546 10.1706 36.3131 12.1548C35.7484 17.201 35.1167 22.1937 34.5521 27.2399C34.2619 30.0016 33.9716 32.7633 33.6871 35.5839C33.8769 35.6265 34.0053 35.6745 34.1951 35.717Z" />
          </svg>
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  .custom-tab {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 5rem;
    padding: 1.5rem 1rem;
    background: transparent;
    border: 0;
    border-bottom: 4px solid transparent;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .custom-tab img {
    max-height: 100%;
    max-width: 140px;
    width: auto;
    object-fit: contain;
  }
  .custom-tab:nth-child(1).is-active { border-bottom-color: #f04c55; }
  .custom-tab:nth-child(2).is-active,
  .custom-tab:nth-child(3).is-active { border-bottom-color: #0474E0; }
  .skill-img img {
    max-height: 56px;
    width: auto;
  }
  #slant-text {
    transform: rotate(-10deg);
  }
</style>

<script>
  const container = document.getElementById("company-tabs");
  if (container) {
    const tabs = container.querySelectorAll<HTMLButtonElement>("[data-tab-index]");
    const panels = container.querySelectorAll<HTMLElement>("[data-panel-index]");
    tabs.forEach((tab) =>
      tab.addEventListener("click", () => {
        const idx = tab.dataset.tabIndex;
        tabs.forEach((t) => t.classList.toggle("is-active", t.dataset.tabIndex === idx));
        panels.forEach((p) => {
          p.hidden = p.dataset.panelIndex !== idx;
        });
      }),
    );
  }
</script>
