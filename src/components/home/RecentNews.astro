---
import { getEntrepreneurialPosts, postUrl } from "~/utils/posts";
import { shortBlogDate } from "~/utils";

const posts = (await getEntrepreneurialPosts()).slice(0, 5);

const ARROW_RIGHT = `<svg width="28" height="28" viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg" class="fill-primary-300 pl-1.5"><path d="M13.3876 22.6917C13.232 22.5361 13.1542 22.3319 13.1542 22.0792C13.1542 21.8264 13.232 21.6222 13.3876 21.4667L19.9792 14.875H5.54175C5.28897 14.875 5.07994 14.7924 4.91466 14.6271C4.74939 14.4618 4.66675 14.2528 4.66675 14C4.66675 13.7472 4.74939 13.5382 4.91466 13.3729C5.07994 13.2076 5.28897 13.125 5.54175 13.125H19.9792L13.3876 6.53334C13.232 6.37778 13.1542 6.16875 13.1542 5.90625C13.1542 5.64375 13.232 5.43473 13.3876 5.27917C13.5431 5.12362 13.7473 5.04584 14.0001 5.04584C14.2529 5.04584 14.457 5.12362 14.6126 5.27917L22.7209 13.3875C22.8181 13.4847 22.8862 13.5819 22.9251 13.6792C22.964 13.7764 22.9834 13.8833 22.9834 14C22.9834 14.0972 22.964 14.1993 22.9251 14.3063C22.8862 14.4132 22.8181 14.5153 22.7209 14.6125L14.6126 22.7208C14.457 22.8764 14.2529 22.9493 14.0001 22.9396C13.7473 22.9299 13.5431 22.8472 13.3876 22.6917Z" /></svg>`;
---

<section class="bg-white py-8 lg:py-36 dark:bg-dark-100">
  <div class="container mx-auto">
    <div class="grid grid-cols-12 gap-8 px-6">
      <div class="col-span-12 lg:col-span-4">
        <h2 class="text-black dark:text-white">What's New?</h2>
        <p class="pb-4 lg:pb-20 lg:text-lg dark:text-white">
          Where expert and undiscovered voices can share their writing on any topic
        </p>
        <a href="/category/entrepreneurial/1/" class="btn btn-secondary">
          <span>Learn More</span>
        </a>
      </div>
      <div class="col-span-12 lg:col-span-8">
        {posts.map((post) => (
          <div
            class="mb-14 grid grid-cols-12 gap-8 border-b pb-14 last-of-type:mb-0 last-of-type:border-0 last-of-type:pb-0"
          >
            <div class="col-span-12 lg:col-span-2">
              <span><strong class="dark:text-white">3 min read</strong></span>
              <p class="text-gray-500 dark:text-white">{shortBlogDate(post.data.date)}</p>
            </div>
            <div class="col-span-12 pr-8 lg:col-span-7">
              <a href={postUrl(post)}>
                <h3 class="text-lg text-black dark:text-white">{post.data.title}</h3>
              </a>
              <p class="text-gray-500 text-base dark:text-white">{post.data.excerpt}</p>
            </div>
            <div class="col-span-12 lg:col-span-3">
              <a href={postUrl(post)} class="btn-link flex items-center">
                <span class="text-primary-300">Learn More</span>
                <Fragment set:html={ARROW_RIGHT} />
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
