---
import type { Post } from "~/utils/posts";
import { postUrl, postThumbnail } from "~/utils/posts";

interface Props {
  post: Post;
}

const { post } = Astro.props;
const href = postUrl(post);
const thumb = postThumbnail(post);
---

<article
  class="blog-card overflow-hidden rounded-lg bg-white dark:bg-dark-400 shadow hover:shadow-xl transition-shadow"
>
  <a href={href} class="block">
    <figure>
      <img src={thumb} alt={post.data.title} class="w-full h-48 object-cover" />
    </figure>
    <div class="p-5">
      <h3 class="text-lg text-black dark:text-white mb-2 hover:text-primary-300 transition-colors">
        {post.data.title}
      </h3>
      <p class="text-sm text-gray-500 dark:text-white line-clamp-3">{post.data.excerpt}</p>
    </div>
    <div class="flex border-t border-slate-500 border-opacity-20 py-3 px-5 text-sm">
      <span class="dark:text-white">3 min read</span>
      <span class="ml-auto text-primary-500 dark:text-primary-200">Read More</span>
    </div>
  </a>
</article>
