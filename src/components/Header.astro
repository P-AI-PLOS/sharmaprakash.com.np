---
import SiteNav from "~/components/SiteNav.astro";
---

<header
  id="site-header"
  class="header top-0 left-0 z-50 h-auto w-full absolute py-8 lg:py-10"
>
  <div class="lg:px-28 px-8 mx-auto">
    <div class="header-inner flex items-center lg:justify-between justify-end">
      <div class="header-mobilenav block lg:hidden">
        <button
          id="mobile-menu-trigger"
          class="btn btn-small text-white btn-transparent px-3 text-3xl"
          aria-label="Open menu"
        >
          ☰
        </button>
      </div>
      <div class="header-nav hidden lg:block">
        <SiteNav />
      </div>
      <div class="header-button hidden lg:block">
        <a class="btn btn-primary btn-small" href="/contact/"><span>Hire me</span></a>
      </div>
    </div>
  </div>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] hidden items-center justify-center bg-grey p-4 text-center lg:hidden"
>
  <button
    id="mobile-menu-close"
    class="absolute top-6 right-6 text-3xl text-white"
    aria-label="Close menu"
  >
    ✕
  </button>
  <ul class="space-y-6 list-none text-2xl">
    <li><a href="/" class="text-white hover:text-primary-300">Home</a></li>
    <li><a href="/blog/page/1/" class="text-white hover:text-primary-300">Blog</a></li>
    <li><a href="/contact/" class="text-white hover:text-primary-300">Contact</a></li>
    <li><a href="/contact/" class="btn btn-primary btn-small"><span>Hire me</span></a></li>
  </ul>
</div>

<script>
  const trigger = document.getElementById("mobile-menu-trigger");
  const menu = document.getElementById("mobile-menu");
  const close = document.getElementById("mobile-menu-close");
  trigger?.addEventListener("click", () => menu?.classList.replace("hidden", "flex"));
  close?.addEventListener("click", () => menu?.classList.replace("flex", "hidden"));

  const header = document.getElementById("site-header");
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 200) {
      header.classList.add(
        "fixed",
        "animate-slidedown",
        "border-b",
        "border-white/20",
        "bg-dark-200/80",
        "backdrop-blur",
        "py-3",
      );
      header.classList.remove("absolute", "py-8", "lg:py-10");
    } else {
      header.classList.remove(
        "fixed",
        "animate-slidedown",
        "border-b",
        "border-white/20",
        "bg-dark-200/80",
        "backdrop-blur",
        "py-3",
      );
      header.classList.add("absolute", "py-8", "lg:py-10");
    }
  };
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
