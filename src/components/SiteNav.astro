---
const pathname = Astro.url.pathname;
const isActive = (href: string, prefix?: string) =>
  pathname === href || (prefix ? pathname.startsWith(prefix) : false);

const items = [
  { href: "/", label: "Home" },
  { href: "/blog/page/1/", label: "Blog", prefix: "/blog/" },
  { href: "/contact/", label: "Contact" },
];
---

<nav>
  <ul class="nav-menu flex list-none gap-8">
    {items.map((item) => (
      <li class="nav-link">
        <a
          href={item.href}
          class:list={[
            "text-white hover:text-primary-200 transition-colors",
            { active: isActive(item.href, item.prefix) },
          ]}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
