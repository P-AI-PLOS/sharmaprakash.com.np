---
import { seriesRegistry } from "~/data/series";
import { getSeriesPosts, type Post } from "~/utils/posts";
import ScrollReveal from "~/components/motion/ScrollReveal.astro";

/**
 * Homepage "Reading paths" section.
 * Text-led, numeral-forward track cards — deliberately distinct from the
 * image-led grids that flank it (RecentEssaysList above, RecentTechnicalPostsCarousel below).
 */

interface TrackEntry {
  slug: string;
  title: string;
  description: string;
  parts: Post[];
  newest: number;
}

const allSlugs = Object.keys(seriesRegistry);
const totalCount = allSlugs.length;

const entriesAll: TrackEntry[] = (
  await Promise.all(
    allSlugs.map(async (slug) => {
      const parts = await getSeriesPosts(slug);
      if (parts.length === 0) return null;
      const newest = Math.max(
        ...parts.map((p) => new Date(p.data.date).getTime()),
      );
      return {
        slug,
        title: seriesRegistry[slug].title,
        description: seriesRegistry[slug].description,
        parts,
        newest,
      } satisfies TrackEntry;
    }),
  )
).filter((e): e is TrackEntry => e !== null);

const tracks = entriesAll
  .sort((a, b) => b.newest - a.newest)
  .slice(0, 3);

const pad = (n: number) => n.toString().padStart(2, "0");
---

{tracks.length > 0 && (
  <section class="bg-surface-sunken py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <ScrollReveal class="flex items-end justify-between gap-6 mb-10 lg:mb-14 flex-wrap">
        <div class="max-w-2xl">
          <p class="eyebrow mb-3">Reading paths · In-depth series</p>
          <h2 class="text-h1 text-strong">
            Pick a track. Each one ships a complete idea end to end.
          </h2>
        </div>
        <a href="/series/" class="btn btn-secondary">
          <span>Browse all {totalCount} {totalCount === 1 ? "series" : "series"} →</span>
        </a>
      </ScrollReveal>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {tracks.map((t, i) => {
          const peek = t.parts.slice(0, 2);
          const remaining = Math.max(0, t.parts.length - peek.length);
          return (
            <ScrollReveal delay={80 * i}>
              <a
                href={`/series/${t.slug}/`}
                class="track-card card-interactive group relative flex h-full flex-col bg-surface-raised rounded-lg p-6 lg:p-8 border border-default"
              >
                <div class="flex items-start justify-between gap-4 mb-5">
                  <span class="track-numeral" aria-hidden="true">{pad(i + 1)}</span>
                  <span class="chip">{t.parts.length} parts</span>
                </div>

                <h3 class="text-h3 text-strong leading-snug group-hover:text-accent-700 transition-colors">
                  {t.title}
                </h3>

                <p class="mt-3 text-body text-muted line-clamp-3">
                  {t.description}
                </p>

                <ol class="mt-6 space-y-2 track-peek">
                  {peek.map((p, idx) => (
                    <li class="flex gap-3 text-body-sm text-default">
                      <span class="text-faint font-mono shrink-0 w-6">{pad(idx + 1)}</span>
                      <span class="line-clamp-1">{p.data.title}</span>
                    </li>
                  ))}
                  {remaining > 0 && (
                    <li class="flex gap-3 text-body-sm text-faint">
                      <span class="font-mono shrink-0 w-6">+</span>
                      <span>{remaining} more {remaining === 1 ? "part" : "parts"}</span>
                    </li>
                  )}
                </ol>

                <div class="mt-8 pt-5 border-t border-default flex items-center justify-between">
                  <span class="text-accent-700 font-semibold text-body-sm link-underline">
                    Start the series →
                  </span>
                </div>
              </a>
            </ScrollReveal>
          );
        })}
      </div>
    </div>
  </section>
)}

<style>
  .track-card {
    transition:
      transform var(--dur-normal) var(--ease-out-quad),
      box-shadow var(--dur-normal) var(--ease-out-quad),
      border-color var(--dur-normal) var(--ease-out-quad);
  }
  .track-card:hover {
    border-color: var(--accent-600);
  }
  .track-numeral {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 72px;
    line-height: 0.85;
    color: var(--text-faint);
    letter-spacing: -0.02em;
    transition: color var(--dur-normal) var(--ease-out-quad);
  }
  .track-card:hover .track-numeral {
    color: var(--accent-600);
  }
  @media (min-width: 1024px) {
    .track-numeral { font-size: 88px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .track-card,
    .track-numeral { transition: none; }
  }
</style>
