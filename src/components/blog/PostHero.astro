---
import type { Post } from "~/utils/posts";
import { postThumbnail } from "~/utils/posts";
import AuthorByline from "./AuthorByline.astro";

interface Props {
  post: Post;
  readingMinutes: number;
  url: string;
}
const { post, readingMinutes, url } = Astro.props;
const cover = postThumbnail(post);
const cats = post.data.category ?? [];
const tags = post.data.tags ?? [];
---

<header class="mx-auto max-w-4xl px-6 lg:px-0 pt-32 pb-10">
  <nav aria-label="Breadcrumb" class="text-body-sm mb-6">
    <ol class="flex flex-wrap items-center gap-x-2 list-none">
      <li><a href="/" class="link-underline text-muted hover:text-default">Home</a></li>
      <li class="text-faint">›</li>
      <li><a href="/blog/page/1/" class="link-underline text-muted hover:text-default">Essays</a></li>
      {cats[0] && (
        <>
          <li class="text-faint">›</li>
          <li class="text-default">{cats[0]}</li>
        </>
      )}
    </ol>
  </nav>

  <div class="flex flex-wrap gap-2 mb-6">
    {cats.map((c) => <span class="chip">{c}</span>)}
  </div>

  <h1 class="text-display-lg lg:text-display-xl text-strong max-w-display">
    {post.data.title}
  </h1>
  {post.data.excerpt && (
    <p class="mt-6 text-body-lg text-muted max-w-reading">{post.data.excerpt}</p>
  )}

  <div class="mt-10">
    <AuthorByline
      date={post.data.date}
      readingMinutes={readingMinutes}
      url={url}
      title={post.data.title}
    />
  </div>

  {tags.length > 0 && (
    <div class="mt-6 flex flex-wrap gap-2">
      {tags.map((t) => <span class="chip">{t}</span>)}
    </div>
  )}
</header>

<figure class="mx-auto max-w-5xl px-6 lg:px-0 mb-12">
  <img
    src={cover}
    alt={post.data.title}
    class="w-full rounded-xl object-cover aspect-[21/9]"
    transition:name={`cover-${post.id}`}
  />
</figure>
