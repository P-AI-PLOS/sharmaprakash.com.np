---
import { Icon } from "@iconify/react";
import { information } from "~/data/site";
---

<section class="author-bio-card">
  <a href="/about/" class="author-bio-avatar" aria-label={information.fullName}>
    <img src={information.thumbImage} alt="" />
  </a>
  <div class="author-bio-body">
    <p class="eyebrow mb-2">About the author</p>
    <h3 class="text-h3 text-strong">{information.fullName}</h3>
    <p class="text-body-sm text-muted mb-3">
      {information.currentRole} · {information.currentCompany}
    </p>
    <p class="text-body text-default">{information.bio}</p>
    <div class="mt-5 flex flex-wrap gap-3">
      <a href={information.socialAddress.linkedin} target="_blank" rel="noopener" class="btn btn-secondary btn-sm">
        <Icon icon="ri:linkedin-fill" client:load />
        <span>Follow on LinkedIn</span>
      </a>
      <a href="/blog/page/1/" class="btn btn-ghost btn-sm">
        <span>More essays →</span>
      </a>
    </div>
  </div>
</section>
