---
import { siteConfig } from "~/data/site";

interface Props {
  identifier: string;
  title: string;
  url: string;
}

const { identifier, title, url } = Astro.props;
const shortname = siteConfig.disqusShortname;
---

<section class="mx-auto max-w-5xl px-6 lg:px-8 pb-20">
  <h2 class="text-strong text-xl font-semibold mb-6">Comments</h2>
  <div
    id="disqus_thread"
    data-disqus-shortname={shortname}
    data-disqus-identifier={identifier}
    data-disqus-title={title}
    data-disqus-url={url}
  >
  </div>
  <noscript>
    Please enable JavaScript to view the
    <a href="https://disqus.com/?ref_noscript" rel="nofollow">
      comments powered by Disqus.
    </a>
  </noscript>
</section>

<script>
  const mount = () => {
    const el = document.getElementById("disqus_thread");
    if (!el) return;

    const shortname = el.dataset.disqusShortname;
    const identifier = el.dataset.disqusIdentifier ?? "";
    const title = el.dataset.disqusTitle ?? "";
    const url = el.dataset.disqusUrl ?? window.location.href;
    if (!shortname) return;

    const w = window as unknown as {
      DISQUS?: { reset: (opts: { reload: boolean; config: () => void }) => void };
      disqus_config?: () => void;
    };

    function disqusConfig(this: {
      page: { url: string; identifier: string; title: string };
    }) {
      this.page.url = url;
      this.page.identifier = identifier;
      this.page.title = title;
    }

    if (w.DISQUS) {
      w.DISQUS.reset({ reload: true, config: disqusConfig });
      return;
    }

    w.disqus_config = disqusConfig;
    const s = document.createElement("script");
    s.src = `https://${shortname}.disqus.com/embed.js`;
    s.setAttribute("data-timestamp", String(+new Date()));
    s.async = true;
    (document.head || document.body).appendChild(s);
  };

  mount();
  document.addEventListener("astro:after-swap", mount);
</script>
