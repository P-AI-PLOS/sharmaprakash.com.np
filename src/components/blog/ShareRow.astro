---
import { Icon } from "@iconify/react";

interface Props {
  url: string;
  title: string;
}
const { url, title } = Astro.props;
const xIntent = `https://x.com/intent/post?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`;
const liIntent = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
---

<div class="share-row" data-share-url={url}>
  <button
    type="button"
    class="share-chip share-copy"
    aria-label="Copy link"
    data-track="share_click"
    data-track-channel="copy"
  >
    <Icon icon="ri:link" client:load />
    <span class="share-copy-label">Copy link</span>
  </button>
  <a
    class="share-chip"
    href={xIntent}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Share on X"
    data-track="share_click"
    data-track-channel="x"
  >
    <Icon icon="ri:twitter-x-fill" client:load />
    <span>X</span>
  </a>
  <a
    class="share-chip"
    href={liIntent}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Share on LinkedIn"
    data-track="share_click"
    data-track-channel="linkedin"
  >
    <Icon icon="ri:linkedin-fill" client:load />
    <span>LinkedIn</span>
  </a>
</div>

<script>
  const init = () => {
    document.querySelectorAll<HTMLButtonElement>(".share-copy").forEach((btn) => {
      if (btn.dataset.wired) return;
      btn.dataset.wired = "1";
      btn.addEventListener("click", async () => {
        const row = btn.closest<HTMLElement>(".share-row");
        const url = row?.dataset.shareUrl || location.href;
        const label = btn.querySelector<HTMLElement>(".share-copy-label");
        try {
          await navigator.clipboard.writeText(url);
          btn.classList.add("is-copied");
          if (label) label.textContent = "Copied";
          setTimeout(() => {
            btn.classList.remove("is-copied");
            if (label) label.textContent = "Copy link";
          }, 1500);
        } catch (e) {
          if (label) label.textContent = "Failed";
        }
      });
    });
  };
  init();
  document.addEventListener("astro:page-load", init);
</script>
