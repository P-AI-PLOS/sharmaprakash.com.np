---
/**
 * A featured/compact card for a blog post. Used in:
 *   - Homepage RecentEssaysList (default + featured variants)
 *   - Homepage RecentTechnicalPostsCarousel
 *   - Essay detail RelatedPosts row
 *
 * The cover image shares a view-transition name with the post hero, so
 * navigation morphs the image cleanly.
 */
import type { Post } from "~/utils/posts";
import { postUrl, postThumbnail } from "~/utils/posts";
import { formatBlogDate } from "~/utils";

interface Props {
  post: Post;
  variant?: "default" | "featured";
}
const { post, variant = "default" } = Astro.props;

const href = postUrl(post);
const cover = postThumbnail(post);
const cat = post.data.category?.[0];
const aspect = variant === "featured" ? "aspect-[16/10]" : "aspect-[16/9]";
const titleType = variant === "featured" ? "text-h2" : "text-h3";
---

<article
  class:list={[
    "card-interactive flex flex-col h-full rounded-lg overflow-hidden bg-surface-raised shadow-md",
  ]}
>
  <a href={href} class="block group">
    <figure class:list={["overflow-hidden", aspect]}>
      <img
        src={cover}
        alt={post.data.title}
        class="h-full w-full object-cover transition-transform duration-slow ease-out-quad group-hover:scale-[1.03]"
        transition:name={`cover-${post.id}`}
      />
    </figure>
    <div class="p-6 flex flex-col gap-3 flex-1">
      <div class="flex items-center gap-3 text-caption text-muted">
        {cat && <span class="chip">{cat}</span>}
        <time datetime={new Date(post.data.date).toISOString()}>
          {formatBlogDate(post.data.date)}
        </time>
      </div>
      <h3 class:list={[titleType, "text-strong line-clamp-2 group-hover:text-accent-700 transition-colors"]}>
        {post.data.title}
      </h3>
      {post.data.excerpt && (
        <p class="text-body-sm text-muted line-clamp-2">{post.data.excerpt}</p>
      )}
    </div>
  </a>
</article>
