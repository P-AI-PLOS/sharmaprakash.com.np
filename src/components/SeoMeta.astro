---
import { siteConfig } from "~/data/site";

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: "website" | "article";
  date?: Date | string;
  lastModified?: Date | string;
  showCanonical?: boolean;
}

const {
  title,
  description = siteConfig.descriptionContent,
  image = siteConfig.metaImage,
  ogType = "website",
  date,
  lastModified,
  showCanonical = false,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const path = Astro.url.pathname;
const canonical = `${siteUrl}${path}`;
const fullImage = image.startsWith("http") ? image : `${siteUrl}${image}`;
const fullTitle = `${title} - ${siteConfig.fullName}`;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={siteConfig.fullName} />

<meta property="og:locale" content="en_US" />
<meta property="og:site_name" content={siteConfig.firstName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImage} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={ogType} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={siteConfig.twitterUsername} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImage} />
<meta name="twitter:url" content={canonical} />

{date && <meta property="article:published_time" content={new Date(date).toISOString()} />}
{lastModified && (
  <meta property="article:modified_time" content={new Date(lastModified).toISOString()} />
)}
{showCanonical && <link rel="canonical" href={canonical} />}
