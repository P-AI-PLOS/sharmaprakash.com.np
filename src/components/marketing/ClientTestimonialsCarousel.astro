---
import { Icon } from "@iconify/react";
import { clientReview } from "~/data/reviews";
---

<section class="testimonials-section relative bg-surface-inverse text-on-inverse py-8 lg:py-28 overflow-hidden">
  <div class="ct-grid-overlay" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-7xl px-6 lg:px-12">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
      <div class="lg:col-span-4">
        <p class="eyebrow text-accent-500 mb-4">Working notes</p>
        <h2 class="text-h1 text-on-inverse max-w-sm">What people say after shipping together.</h2>
        <p class="mt-5 text-body-lg text-on-inverse-muted max-w-md">
          A few field notes from clients and peers who worked with me across product,
          engineering, and company-building.
        </p>
      </div>

      <div class="lg:col-span-8">
        {/* Mobile: scroll-snap strip with 3× items for infinite loop feel */}
        <div class="ct-mobile-scroll" id="ct-mobile-scroll">
          {[...clientReview, ...clientReview, ...clientReview].map((r, i) => {
            const quote = r.featuredText ?? r.text;
            const isShort = quote.length < 150;
            return (
              <blockquote class="ct-panel ct-mobile-card" aria-hidden={i < clientReview.length || i >= clientReview.length * 2 ? "true" : undefined}>
                <div class="ct-mark" aria-hidden="true">
                  <Icon icon="ri:double-quotes-l" width="34" height="34" client:load />
                </div>
                <p class:list={["ct-text", { "ct-text--short": isShort }]} set:html={quote} />
                <footer class="ct-footer">
                  <div class="ct-person">
                    <img src={r.image} alt={r.name} class="ct-avatar" />
                    <div>
                      <cite class="not-italic font-semibold text-on-inverse block">{r.name}</cite>
                      <span class="text-body-sm text-on-inverse-muted">{r.meta}</span>
                    </div>
                  </div>
                </footer>
              </blockquote>
            );
          })}
        </div>

        {/* Tablet+: Swiper carousel */}
        <swiper-container class="ct-swiper" slides-per-view="1" loop="true" autoplay-delay="6500">
          {clientReview.map((r) => {
            const quote = r.featuredText ?? r.text;
            const isShort = quote.length < 150;

            return (
              <swiper-slide>
                <blockquote class="ct-panel">
                  <div class="ct-mark" aria-hidden="true">
                    <Icon icon="ri:double-quotes-l" width="34" height="34" client:load />
                  </div>
                  <p
                    class:list={["ct-text", { "ct-text--short": isShort }]}
                    set:html={quote}
                  />
                  <footer class="ct-footer">
                    <div class="ct-person">
                      <img src={r.image} alt={r.name} class="ct-avatar" />
                      <div>
                        <cite class="not-italic font-semibold text-on-inverse block">{r.name}</cite>
                        <span class="text-body-sm text-on-inverse-muted">{r.meta}</span>
                      </div>
                    </div>
                  </footer>
                </blockquote>
              </swiper-slide>
            );
          })}
        </swiper-container>
        <div class="ct-nav" aria-label="Testimonial navigation">
          <button type="button" aria-label="Previous testimonial" class="ct-prev ct-nav-button">
            <Icon icon="ri:arrow-left-line" width="18" height="18" client:load />
          </button>
          <button type="button" aria-label="Next testimonial" class="ct-next ct-nav-button">
            <Icon icon="ri:arrow-right-line" width="18" height="18" client:load />
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .testimonials-section {
    background:
      linear-gradient(135deg, var(--ink-950) 0%, var(--ink-900) 46%, var(--ink-800) 100%);
  }

  .ct-grid-overlay {
    position: absolute;
    inset: 0;
    opacity: 0.22;
    background-image:
      linear-gradient(color-mix(in oklab, var(--ink-300), transparent 92%) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in oklab, var(--ink-300), transparent 92%) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: linear-gradient(90deg, transparent, var(--ink-950) 16%, var(--ink-950) 84%, transparent);
  }

  /* Mobile scroll-snap infinite strip */
  .ct-mobile-scroll {
    display: flex;
    gap: var(--space-4);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: var(--space-2);
  }
  .ct-mobile-scroll::-webkit-scrollbar { display: none; }
  .ct-mobile-card {
    flex: 0 0 85vw;
    max-width: 360px;
    scroll-snap-align: start;
  }
  @media (min-width: 640px) { .ct-mobile-scroll { display: none; } }

  .ct-swiper {
    --swiper-theme-color: var(--accent-500);
    display: none;
    width: 100%;
    overflow: visible;
  }
  @media (min-width: 640px) { .ct-swiper { display: block; } }


  .ct-panel {
    position: relative;
    display: flex;
    min-height: 420px;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-10);
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--ink-300), transparent 84%);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(145deg, color-mix(in oklab, var(--ink-900), transparent 8%), color-mix(in oklab, var(--ink-800), transparent 18%));
    padding: var(--space-8);
    box-shadow: 0 24px 80px -48px color-mix(in oklab, var(--accent-600), transparent 12%);
  }

  .ct-panel::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-600), transparent 70%);
  }

  .ct-mark {
    display: inline-flex;
    width: 56px;
    height: 56px;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in oklab, var(--accent-500), transparent 55%);
    border-radius: var(--radius-pill);
    background: color-mix(in oklab, var(--accent-600), transparent 88%);
    color: var(--accent-500);
  }

  .ct-text {
    max-width: 760px;
    color: var(--text-on-inverse);
    font-size: 28px;
    line-height: 1.24;
    font-weight: 600;
  }

  .ct-text--short {
    max-width: 680px;
    font-size: 34px;
    line-height: 1.18;
  }

  .ct-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    border-top: 1px solid color-mix(in oklab, var(--ink-300), transparent 86%);
    padding-top: var(--space-6);
  }

  .ct-person {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: var(--space-4);
  }

  .ct-avatar {
    width: 56px;
    height: 56px;
    flex: 0 0 auto;
    border: 2px solid color-mix(in oklab, var(--accent-500), transparent 55%);
    border-radius: var(--radius-full);
    object-fit: cover;
    transition:
      transform var(--dur-normal) var(--ease-out-quad),
      border-color var(--dur-normal) var(--ease-out-quad);
  }

  .ct-panel:hover .ct-avatar {
    transform: scale(1.06);
    border-color: var(--accent-500);
  }

  .ct-nav {
    display: none;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-2);
    margin-top: var(--space-6);
  }
  @media (min-width: 640px) { .ct-nav { display: flex; } }

  .ct-nav-button {
    display: inline-flex;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in oklab, var(--ink-300), transparent 75%);
    border-radius: var(--radius-pill);
    background: color-mix(in oklab, var(--ink-900), transparent 25%);
    color: var(--text-on-inverse-muted);
    cursor: pointer;
    transition:
      background-color var(--dur-fast) var(--ease-out-quad),
      border-color var(--dur-fast) var(--ease-out-quad),
      color var(--dur-fast) var(--ease-out-quad),
      transform var(--dur-fast) var(--ease-out-quad);
  }

  .ct-nav-button:hover {
    border-color: var(--accent-500);
    background: var(--accent-600);
    color: var(--ink-50);
    transform: translateY(-1px);
  }

  /* Per-slide entrance: elements lift in once the slide becomes active. */
  .ct-swiper swiper-slide .ct-mark,
  .ct-swiper swiper-slide .ct-text,
  .ct-swiper swiper-slide .ct-footer {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity var(--dur-slow) var(--ease-out-expo),
      transform var(--dur-slow) var(--ease-out-expo);
  }
  .ct-swiper swiper-slide.swiper-slide-active .ct-mark   { opacity: 1; transform: none; transition-delay: 0ms; }
  .ct-swiper swiper-slide.swiper-slide-active .ct-text   { opacity: 1; transform: none; transition-delay: 140ms; }
  .ct-swiper swiper-slide.swiper-slide-active .ct-footer { opacity: 1; transform: none; transition-delay: 280ms; }

  @media (max-width: 1023px) {
    .ct-panel {
      min-height: 380px;
    }

    .ct-text,
    .ct-text--short {
      font-size: 24px;
      line-height: 1.28;
    }
  }

  @media (max-width: 640px) {
    .ct-panel {
      min-height: 420px;
      gap: var(--space-8);
      padding: var(--space-6);
    }

    .ct-text,
    .ct-text--short {
      font-size: 21px;
      line-height: 1.32;
    }

    .ct-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .ct-nav {
      justify-content: flex-start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ct-swiper swiper-slide .ct-mark,
    .ct-swiper swiper-slide .ct-text,
    .ct-swiper swiper-slide .ct-footer { opacity: 1; transform: none; transition: none; }
    .ct-avatar,
    .ct-nav-button { transition: none; }
  }
</style>

<script>
  import { register } from "swiper/element/bundle";
  register();

  const initTestimonials = () => {
    document.querySelectorAll(".testimonials-section").forEach((section) => {
      if (section instanceof HTMLElement && section.dataset.testimonialsReady === "true") return;

      const swiper = section.querySelector<any>(".ct-swiper");
      const previous = section.querySelector(".ct-prev");
      const next = section.querySelector(".ct-next");
      if (!(section instanceof HTMLElement) || !swiper || !previous || !next) return;

      section.dataset.testimonialsReady = "true";
      previous.addEventListener("click", () => swiper.swiper?.slidePrev());
      next.addEventListener("click", () => swiper.swiper?.slideNext());
    });
  };

  const fixSwiperWidth = () => {
    const el = document.querySelector<any>(".ct-swiper");
    if (!el) return;
    const observer = new ResizeObserver(() => {
      if (el.swiper) { el.swiper.update(); observer.disconnect(); }
    });
    observer.observe(el);
  };

  const initMobileLoop = () => {
    const strip = document.getElementById("ct-mobile-scroll");
    if (!strip || window.innerWidth >= 640) return;
    if ((strip as any)._loopReady) return;
    (strip as any)._loopReady = true;

    const cards = strip.querySelectorAll<HTMLElement>(".ct-mobile-card");
    const count = cards.length / 3;
    const gap = 16;

    const jumpToMiddle = () => {
      const cardWidth = cards[0].offsetWidth + gap;
      const setWidth = count * cardWidth;
      // Start at the middle set, no animation
      strip.scrollTo({ left: setWidth, behavior: "instant" });
    };
    jumpToMiddle();

    let ticking = false;
    strip.addEventListener("scroll", () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const cardWidth = cards[0].offsetWidth + gap;
        const setWidth = count * cardWidth;
        if (strip.scrollLeft < setWidth * 0.25) {
          strip.scrollLeft += setWidth;
        } else if (strip.scrollLeft >= setWidth * 2) {
          strip.scrollLeft -= setWidth;
        }
        ticking = false;
      });
    }, { passive: true });
  };

  initTestimonials();
  fixSwiperWidth();
  initMobileLoop();
  document.addEventListener("astro:page-load", () => {
    initTestimonials();
    fixSwiperWidth();
    initMobileLoop();
  });
</script>
