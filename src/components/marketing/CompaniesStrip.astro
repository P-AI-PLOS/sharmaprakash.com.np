---
import { companyInformation } from "~/data/companies";

const logos = [
  { name: "Truemark", src: "/images/asset/truemark.png" },
  { name: "Invoice Work", src: "/images/asset/invoiceWork.png" },
  { name: "All Brainy Labs", src: "/images/asset/allBrainyLabs.png" },
];
const logoBySite = Object.fromEntries(companyInformation.map((c, i) => [c.companyName, logos[i]]));
---

<section class="bg-surface-base border-y border-default">
  <div class="mx-auto max-w-7xl px-6 lg:px-12 py-16 lg:py-20">
    <div class="grid lg:grid-cols-4 gap-10 items-center">
      <div>
        <p class="eyebrow mb-2">Currently building</p>
        <h2 class="text-h2 text-strong">Three companies, one playbook.</h2>
      </div>
      <ul class="lg:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-8 list-none">
        {companyInformation.map((c) => {
          const logo = logoBySite[c.companyName];
          return (
            <li>
              <a
                href={c.siteUrl}
                target="_blank"
                rel="noopener"
                class="card-interactive block rounded-lg bg-surface-raised shadow-md p-6 h-full"
              >
                {logo && (
                  <img src={logo.src} alt={c.companyName} class="h-8 w-auto mb-4 object-contain object-left" />
                )}
                <p class="text-body-sm text-muted line-clamp-3" set:html={c.companyDescription} />
                <span class="mt-4 inline-block text-accent-700 font-semibold link-underline">
                  Visit →
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </div>
</section>
