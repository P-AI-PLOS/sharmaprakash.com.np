---
import { Icon } from "@iconify/react";
import ScrollReveal from "~/components/motion/ScrollReveal.astro";
import { information } from "~/data/site";

const endpoint = import.meta.env.PUBLIC_NEWSLETTER_ENDPOINT ?? "";
const hasEndpoint = endpoint.length > 0;
---

<section class="bg-surface-base py-24 lg:py-32">
  <div class="mx-auto max-w-5xl px-6 lg:px-12">
    <ScrollReveal>
      <div class="newsletter-card">
        <p class="eyebrow mb-3">Stay in the loop</p>
        <h2 class="text-h1 text-strong mb-4">Get new essays in your inbox.</h2>
        <p class="text-body-lg text-muted max-w-2xl mb-8">
          I'm pumping out an AI essay series. Drop your email to get each one when
          it ships — no spam, unsubscribe anytime.
        </p>

        <form
          class="newsletter-form"
          data-endpoint={endpoint}
          data-fallback={hasEndpoint ? "false" : "true"}
        >
          <label class="sr-only" for="newsletter-email">Email address</label>
          <input
            id="newsletter-email"
            class="field-input newsletter-input"
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            autocomplete="email"
          />
          <button type="submit" class="btn btn-primary newsletter-submit">
            <span>Subscribe</span>
            <Icon icon="ri:arrow-right-line" client:load />
          </button>
        </form>

        <p class="text-body-sm text-faint mt-4 newsletter-status" aria-live="polite">
          {hasEndpoint
            ? "One email per essay. Never shared."
            : (
              <>
                Email signup landing soon — meanwhile, follow along on{" "}
                <a
                  href={information.socialAddress.linkedin}
                  target="_blank"
                  rel="noopener"
                  class="link-underline text-accent-700"
                >LinkedIn</a>.
              </>
            )}
        </p>
      </div>
    </ScrollReveal>
  </div>
</section>

<style>
  .newsletter-card {
    background: var(--surface-raised);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    padding: var(--space-12) var(--space-8);
  }
  @media (min-width: 1024px) {
    .newsletter-card { padding: var(--space-16) var(--space-16); }
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 560px;
  }
  @media (min-width: 640px) {
    .newsletter-form { flex-direction: row; }
  }
  .newsletter-input { flex: 1; }
  .newsletter-submit { flex-shrink: 0; }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  const init = () => {
    const form = document.querySelector<HTMLFormElement>(".newsletter-form");
    if (!form || form.dataset.wired) return;
    form.dataset.wired = "1";
    const status = document.querySelector<HTMLElement>(".newsletter-status");
    const isFallback = form.dataset.fallback === "true";

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = (form.querySelector<HTMLInputElement>('input[name="email"]')?.value ?? "").trim();
      if (!email) return;

      if (isFallback) {
        if (status) status.textContent = "Thanks — the form isn't live yet. Reach me on LinkedIn for now.";
        return;
      }

      const endpoint = form.dataset.endpoint || "";
      try {
        const res = await fetch(endpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json", "Accept": "application/json" },
          body: JSON.stringify({ email }),
        });
        if (res.ok) {
          form.reset();
          if (status) status.textContent = "Subscribed. Next essay is on the way.";
          form.querySelectorAll("input, button").forEach((el) => ((el as HTMLInputElement).disabled = true));
        } else {
          if (status) status.textContent = "Something went wrong. Try again, or email me directly.";
        }
      } catch (err) {
        if (status) status.textContent = "Network glitch. Try again in a moment.";
      }
    });
  };
  init();
  document.addEventListener("astro:page-load", init);
</script>
