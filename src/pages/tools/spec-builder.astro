---
import SiteShell from "~/layouts/SiteShell.astro";
import SpecBuilder from "~/components/tools/spec-builder/SpecBuilder.tsx";
---

<SiteShell
  title="Spec Builder — Free Tool"
  description="Turn an opportunity and a solution into a spec — a lightweight PRD, a Shape Up pitch, or a story-map outline — with acceptance criteria that survive the handoff. Free, right in your browser."
>
  <section class="bg-surface-base pt-40 pb-12">
    <div class="mx-auto max-w-3xl px-6 lg:px-12 text-center">
      <p class="eyebrow mb-3">Free tool</p>
      <h1 class="text-display-lg text-strong">Spec Builder</h1>
      <p class="mt-4 text-body-lg text-muted max-w-xl mx-auto">
        Discovery gave you an opportunity worth solving. This turns it into something a team can
        act on — a <strong class="text-strong">lightweight PRD</strong> when you're handing off scope, a
        <strong class="text-strong">Shape Up pitch</strong> when you're aligning a room, a
        <strong class="text-strong">story-map outline</strong> when you're sequencing a release — plus the
        acceptance criteria that outlive whichever shape you chose. Everything saves in your browser.
      </p>
      <p class="mt-3 text-caption text-muted">
        Comes from an <a href="/tools/opportunity-solution-tree/" class="link-underline text-accent-700">opportunity solution tree</a> ·
        <a href="/course/continuous-discovery/" class="link-underline text-accent-700">take the free course</a> ·
        <a
          href="/product-management/making-discovery-a-habit-cdh-alongside-shape-up-okrs-and-agile/"
          class="link-underline text-accent-700">how this fits with Shape Up, OKRs and agile</a
        >
      </p>
    </div>
  </section>

  <section class="bg-surface-base pb-24">
    <div class="mx-auto max-w-5xl px-6 lg:px-12">
      <SpecBuilder
        client:load
        kicker="Free tool"
        title="Build your spec"
        instructions="Start from an opportunity you already found, say what job the spec has to do, then write it in the format that fits. It saves in your browser — nothing is sent anywhere."
      />
    </div>
  </section>
</SiteShell>
