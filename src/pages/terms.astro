---
import fs from "node:fs/promises";
import path from "node:path";
import matter from "gray-matter";
import { marked } from "marked";
import SiteShell from "~/layouts/SiteShell.astro";
import { headTitle } from "~/data/site";

const raw = await fs.readFile(path.join(process.cwd(), "src/data/static/terms.md"), "utf-8");
const { content } = matter(raw);
const html = marked.parse(content);
---

<SiteShell title={headTitle.termsTitle}>
  <section class="bg-surface-base pt-40 pb-12">
    <div class="mx-auto max-w-reading px-6 lg:px-0">
      <p class="eyebrow mb-3">Legal</p>
      <h1 class="text-display-lg text-strong">Terms &amp; privacy.</h1>
    </div>
  </section>

  <section class="bg-surface-base pb-24">
    <div class="mx-auto max-w-reading px-6 lg:px-0 prose-post" set:html={html} />
  </section>
</SiteShell>
