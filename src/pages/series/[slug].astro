---
import type { GetStaticPaths } from "astro";
import SiteShell from "~/layouts/SiteShell.astro";
import ScrollReveal from "~/components/motion/ScrollReveal.astro";
import { seriesRegistry } from "~/data/series";
import {
  getSeriesPosts,
  postUrl,
  estimateReadMinutes,
  type Post,
} from "~/utils/posts";
import { formatBlogDate } from "~/utils";

export const getStaticPaths = (async () => {
  return Object.entries(seriesRegistry).map(([slug, meta]) => ({
    params: { slug },
    props: { slug, meta },
  }));
}) satisfies GetStaticPaths;

const { slug, meta } = Astro.props as {
  slug: string;
  meta: { title: string; description: string; cover: string };
};

const parts: Post[] = await getSeriesPosts(slug);
const first = parts[0];
const cover = meta.cover;
const firstDate = first ? formatBlogDate(first.data.date) : "";
const partWord = parts.length === 1 ? "part" : "parts";
const pad = (n: number) => String(n).padStart(2, "0");
---

<SiteShell title={`${meta.title} · Series`} description={meta.description}>
  <section class="bg-surface-base pt-40 pb-12">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7">
        <p class="eyebrow mb-3">Series</p>
        <h1 class="text-display-lg text-strong">{meta.title}</h1>
        <p class="mt-5 text-body-lg text-muted max-w-reading">{meta.description}</p>
        {parts.length > 0 && (
          <p class="mt-4 text-caption text-faint">
            {parts.length} {partWord}
            {firstDate && <> · first published <time datetime={new Date(first.data.date).toISOString()}>{firstDate}</time></>}
          </p>
        )}
        {first && (
          <div class="mt-8">
            <a href={postUrl(first)} class="btn btn-primary">
              <span>Start with part 1 →</span>
            </a>
          </div>
        )}
      </div>
      {cover && (
        <figure class="lg:col-span-5 aspect-[21/9] lg:aspect-[4/3] overflow-hidden rounded-xl bg-ink-100 shadow-md">
          <img src={cover} alt={meta.title} class="h-full w-full object-cover" />
        </figure>
      )}
    </div>
  </section>

  <section class="pb-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      {parts.length === 0 ? (
        <p class="text-muted">No parts published yet.</p>
      ) : (
        <ol class="list-none grid grid-cols-1 gap-4 max-w-4xl">
          {parts.map((post, i) => {
            const minutes = estimateReadMinutes(post.body);
            return (
              <ScrollReveal delay={60 * i} as="li">
                <a
                  href={postUrl(post)}
                  class="card-interactive group block bg-surface-raised rounded-lg p-6 lg:p-8"
                >
                  <div class="grid grid-cols-[auto_1fr] gap-6 items-start">
                    <span class="text-display-sm font-bold text-accent-700 leading-none">{pad(i + 1)}</span>
                    <div>
                      <h2 class="text-h3 text-strong group-hover:text-accent-700 transition-colors">
                        {post.data.title}
                      </h2>
                      {post.data.excerpt && (
                        <p class="mt-3 text-body text-muted line-clamp-3 max-w-reading">{post.data.excerpt}</p>
                      )}
                      <div class="mt-4 flex items-center gap-3 text-caption text-muted">
                        <time datetime={new Date(post.data.date).toISOString()}>
                          {formatBlogDate(post.data.date)}
                        </time>
                        <span class="text-faint">·</span>
                        <span>{minutes} min read</span>
                      </div>
                    </div>
                  </div>
                </a>
              </ScrollReveal>
            );
          })}
        </ol>
      )}

      {first && parts.length > 1 && (
        <div class="mt-12 flex justify-center">
          <a href={postUrl(first)} class="btn btn-primary">
            <span>Start with part 1 →</span>
          </a>
        </div>
      )}
    </div>
  </section>
</SiteShell>
