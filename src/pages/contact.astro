---
import { Icon } from "@iconify/react";
import SiteShell from "~/layouts/SiteShell.astro";
import ScrollReveal from "~/components/motion/ScrollReveal.astro";
import { headTitle, information } from "~/data/site";
---

<SiteShell title={headTitle.contactTitle}>
  <section class="bg-surface-base pt-40 pb-12">
    <div class="mx-auto max-w-3xl px-6 lg:px-12 text-center">
      <p class="eyebrow mb-3">Contact</p>
      <h1 class="text-display-lg text-strong">Say hello.</h1>
      <p class="mt-4 text-body-lg text-muted max-w-xl mx-auto">
        Product, engineering, founders, agentic AI, or just a thoughtful note about
        something you read here. I read every message.
      </p>
    </div>
  </section>

  <section class="bg-surface-base pb-24">
    <div class="mx-auto max-w-5xl px-6 lg:px-12 grid lg:grid-cols-5 gap-12">
      <ScrollReveal class="lg:col-span-2 space-y-6">
        <div class="flex items-start gap-4">
          <span class="flex h-12 w-12 items-center justify-center rounded-pill bg-accent-100 text-accent-700 shrink-0">
            <Icon icon="ri:mail-line" width="22" client:load />
          </span>
          <div>
            <p class="eyebrow mb-1">Email</p>
            {information.emailAddress.map((e) => (
              <a href={`mailto:${e}`} class="link-underline text-default block">{e}</a>
            ))}
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="flex h-12 w-12 items-center justify-center rounded-pill bg-accent-100 text-accent-700 shrink-0">
            <Icon icon="ri:phone-line" width="22" client:load />
          </span>
          <div>
            <p class="eyebrow mb-1">Phone</p>
            {information.phoneNumbers.map((n) => (
              <a href={`tel:${n.replaceAll("-", "")}`} class="link-underline text-default block">{n}</a>
            ))}
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="flex h-12 w-12 items-center justify-center rounded-pill bg-accent-100 text-accent-700 shrink-0">
            <Icon icon="ri:map-pin-line" width="22" client:load />
          </span>
          <div>
            <p class="eyebrow mb-1">Where</p>
            <p class="text-default">{information.address}</p>
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={150} class="lg:col-span-3">
        <form
          class="card-interactive rounded-lg bg-surface-raised shadow-md p-8 space-y-5"
          action={`mailto:${information.emailAddress[0]}`}
          method="post"
          enctype="text/plain"
        >
          <div class="field">
            <label class="field-label" for="name">Your name</label>
            <input class="field-input" type="text" name="name" id="name" required autocomplete="name" />
          </div>
          <div class="field">
            <label class="field-label" for="email">Email</label>
            <input class="field-input" type="email" name="email" id="email" required autocomplete="email" />
          </div>
          <div class="field">
            <label class="field-label" for="subject">Subject</label>
            <input class="field-input" type="text" name="subject" id="subject" required />
          </div>
          <div class="field">
            <label class="field-label" for="message">Message</label>
            <textarea class="field-textarea" name="message" id="message" rows="6" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-lg w-full justify-center">
            <span>Send</span>
            <Icon icon="ri:send-plane-line" client:load />
          </button>
        </form>
      </ScrollReveal>
    </div>
  </section>
</SiteShell>
