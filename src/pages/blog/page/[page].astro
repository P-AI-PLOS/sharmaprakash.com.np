---
import type { GetStaticPaths } from "astro";
import SiteShell from "~/layouts/SiteShell.astro";
import PostsSidebar from "~/components/blog/PostsSidebar.astro";
import SeriesStrip from "~/components/blog/SeriesStrip.astro";
import ScrollReveal from "~/components/motion/ScrollReveal.astro";
import { headTitle } from "~/data/site";
import {
  getBlogPosts,
  postUrl,
  postThumbnail,
  POSTS_PER_PAGE,
} from "~/utils/posts";
import Pagination from "~/components/blog/Pagination.astro";
import { formatBlogDate } from "~/utils";

export const getStaticPaths = (async () => {
  const posts = await getBlogPosts();
  const total = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
  return Array.from({ length: total }, (_, i) => {
    const pageNum = i + 1;
    const start = i * POSTS_PER_PAGE;
    return {
      params: { page: String(pageNum) },
      props: {
        posts: posts.slice(start, start + POSTS_PER_PAGE),
        currentPage: pageNum,
        totalPages: total,
      },
    };
  });
}) satisfies GetStaticPaths;

const { posts, currentPage, totalPages } = Astro.props as {
  posts: Awaited<ReturnType<typeof getBlogPosts>>;
  currentPage: number;
  totalPages: number;
};
---

<SiteShell title={`${headTitle.blogsTitle} · Page ${currentPage}`}>
  <section class="bg-surface-base pt-40 pb-12">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <p class="eyebrow mb-3">The reading list</p>
      <h1 class="text-display-lg text-strong max-w-2xl">Essays, tech notes, and the in-between.</h1>
    </div>
  </section>

  {currentPage === 1 && <SeriesStrip />}

  <section class="pb-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-8">
        <ul class="list-none divide-y divide-[var(--border-default)]">
          {posts.map((post, i) => (
            <ScrollReveal delay={Math.min(i, 4) * 40} as="li">
              <a href={postUrl(post)} class="group block py-10 grid grid-cols-1 md:grid-cols-[1fr_180px] gap-8 items-start">
                <div>
                  <div class="flex items-center gap-3 text-caption text-muted mb-3">
                    {post.data.category?.[0] && <span class="chip">{post.data.category[0]}</span>}
                    <time datetime={new Date(post.data.date).toISOString()}>
                      {formatBlogDate(post.data.date)}
                    </time>
                    <span class="text-faint">·</span>
                    <span>3 min read</span>
                  </div>
                  <h2 class="text-h2 text-strong group-hover:text-accent-700 transition-colors">
                    {post.data.title}
                  </h2>
                  {post.data.excerpt && (
                    <p class="mt-3 text-body-lg text-muted max-w-reading">{post.data.excerpt}</p>
                  )}
                </div>
                <figure class="hidden md:block aspect-[4/3] overflow-hidden rounded-lg">
                  <img
                    src={postThumbnail(post)}
                    alt={post.data.title}
                    class="h-full w-full object-cover transition-transform duration-slow ease-out-quad group-hover:scale-[1.04]"
                    transition:name={`cover-${post.id}`}
                  />
                </figure>
              </a>
            </ScrollReveal>
          ))}
        </ul>

        <Pagination
          currentPage={currentPage}
          totalPages={totalPages}
          buildUrl={(p) => `/blog/page/${p}/`}
        />
      </div>

      <div class="lg:col-span-4">
        <PostsSidebar />
      </div>
    </div>
  </section>
</SiteShell>
