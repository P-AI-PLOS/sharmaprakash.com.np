---
import type { GetStaticPaths } from "astro";
import { render } from "astro:content";
import SiteShell from "~/layouts/SiteShell.astro";
import ReadingProgressBar from "~/components/blog/ReadingProgressBar.astro";
import CodeBlockEnhancements from "~/components/blog/CodeBlockEnhancements.astro";
import CourseSidebar from "~/components/course/CourseSidebar.astro";
import CourseChapterNav from "~/components/course/CourseChapterNav.astro";
import { courseRegistry } from "~/data/courses";
import { getCourse, courseUrl } from "~/utils/courses";
import { estimateReadMinutes, postCoverImage } from "~/utils/posts";

export const getStaticPaths = (async () => {
  const paths = [] as { params: { slug: string; chapter: string } }[];
  for (const [slug, meta] of Object.entries(courseRegistry)) {
    for (const ch of meta.chapters) {
      paths.push({ params: { slug, chapter: ch.slug } });
    }
  }
  return paths;
}) satisfies GetStaticPaths;

const { slug, chapter: chapterSlug } = Astro.params as {
  slug: string;
  chapter: string;
};
const course = await getCourse(slug);
if (!course) throw new Error(`Course not found: ${slug}`);
const current = course.chapters.find((c) => c.slug === chapterSlug);
if (!current) throw new Error(`Chapter not found: ${slug}/${chapterSlug}`);
const prev = course.chapters[current.index - 1];
const next = course.chapters[current.index + 1];

const { Content } = await render(current.post);
const minutes = estimateReadMinutes(current.post.body);
const pad = (n: number) => String(n + 1).padStart(2, "0");
---

<SiteShell
  title={`${current.label} · ${course.meta.title}`}
  description={current.post.data.excerpt}
  image={postCoverImage(current.post)}
  ogType="article"
>
  <ReadingProgressBar />

  <article class="bg-surface-base pt-32 pb-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <nav class="mb-8 text-caption text-muted">
        <a href="/course/" class="link-underline">Courses</a>
        <span class="mx-2 text-faint">/</span>
        <a href={courseUrl(slug)} class="link-underline">{course.meta.title}</a>
      </nav>

      <div class="grid lg:grid-cols-[260px_1fr] gap-10 lg:gap-14 items-start">
        <CourseSidebar course={course} currentSlug={chapterSlug} />

        <div class="min-w-0 max-w-reading">
          <header class="mb-8">
            <p class="eyebrow mb-2">Chapter {pad(current.index)} · {minutes} min</p>
            <h1 class="text-h1 text-strong">{current.label}</h1>
            {current.post.data.excerpt && (
              <p class="mt-3 text-body text-muted">{current.post.data.excerpt}</p>
            )}
          </header>

          {current.audio && (
            <figure class="mb-8 bg-surface-raised rounded-lg p-4">
              <figcaption class="text-caption text-muted mb-2">Audio lesson</figcaption>
              <audio controls preload="none" src={current.audio} class="w-full"></audio>
            </figure>
          )}

          <div class="prose-post">
            <Content />
          </div>

          <CodeBlockEnhancements />

          <CourseChapterNav
            courseSlug={slug}
            current={current}
            prev={prev}
            next={next}
            totalChapters={course.chapters.length}
          />
        </div>
      </div>
    </div>
  </article>
</SiteShell>
