---
import type { GetStaticPaths } from "astro";
import SiteShell from "~/layouts/SiteShell.astro";
import PostsSidebar from "~/components/blog/PostsSidebar.astro";
import ScrollReveal from "~/components/motion/ScrollReveal.astro";
import { headTitle } from "~/data/site";
import {
  getUniqueCategories,
  getPostsByCategorySlug,
  postUrl,
  postThumbnail,
  POSTS_PER_PAGE,
} from "~/utils/posts";
import { createSlug, formatBlogDate } from "~/utils";

export const getStaticPaths = (async () => {
  const cats = await getUniqueCategories();
  const out = [];
  for (const cat of cats) {
    const slug = createSlug(cat);
    const posts = await getPostsByCategorySlug(slug);
    const total = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
    for (let i = 0; i < total; i++) {
      const pageNum = i + 1;
      const start = i * POSTS_PER_PAGE;
      out.push({
        params: { slug, page: String(pageNum) },
        props: {
          posts: posts.slice(start, start + POSTS_PER_PAGE),
          currentPage: pageNum,
          totalPages: total,
          category: cat,
          slug,
        },
      });
    }
  }
  return out;
}) satisfies GetStaticPaths;

const { posts, currentPage, totalPages, category, slug } = Astro.props as {
  posts: Awaited<ReturnType<typeof getPostsByCategorySlug>>;
  currentPage: number;
  totalPages: number;
  category: string;
  slug: string;
};
---

<SiteShell title={`${category} · ${headTitle.blogsTitle}`}>
  <section class="bg-surface-base pt-40 pb-12">
    <div class="mx-auto max-w-7xl px-6 lg:px-12">
      <p class="eyebrow mb-3">Category</p>
      <h1 class="text-display-lg text-strong capitalize">{category}</h1>
    </div>
  </section>

  <section class="pb-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-8">
        <ul class="list-none divide-y divide-default">
          {posts.map((post, i) => (
            <ScrollReveal delay={60 * i} as="li">
              <a href={postUrl(post)} class="group block py-10 grid grid-cols-1 md:grid-cols-[1fr_180px] gap-8 items-start">
                <div>
                  <div class="flex items-center gap-3 text-caption text-muted mb-3">
                    <time datetime={new Date(post.data.date).toISOString()}>
                      {formatBlogDate(post.data.date)}
                    </time>
                    <span class="text-faint">·</span>
                    <span>3 min read</span>
                  </div>
                  <h2 class="text-h2 text-strong group-hover:text-accent-700 transition-colors">
                    {post.data.title}
                  </h2>
                  {post.data.excerpt && (
                    <p class="mt-3 text-body-lg text-muted max-w-reading">{post.data.excerpt}</p>
                  )}
                </div>
                <figure class="hidden md:block aspect-[4/3] overflow-hidden rounded-lg">
                  <img
                    src={postThumbnail(post)}
                    alt={post.data.title}
                    class="h-full w-full object-cover transition-transform duration-slow ease-out-quad group-hover:scale-[1.04]"
                    transition:name={`cover-${post.id}`}
                  />
                </figure>
              </a>
            </ScrollReveal>
          ))}
        </ul>

        <nav class="mt-12 flex justify-between items-center" aria-label="Pagination">
          {currentPage > 1 ? (
            <a href={`/category/${slug}/${currentPage - 1}/`} class="btn btn-secondary">
              <span>← Newer</span>
            </a>
          ) : <span />}
          <span class="text-body-sm text-muted">Page {currentPage} of {totalPages}</span>
          {currentPage < totalPages ? (
            <a href={`/category/${slug}/${currentPage + 1}/`} class="btn btn-secondary">
              <span>Older →</span>
            </a>
          ) : <span />}
        </nav>
      </div>

      <div class="lg:col-span-4">
        <PostsSidebar />
      </div>
    </div>
  </section>
</SiteShell>
